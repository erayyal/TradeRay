# ============================================================================
# TradeRay v1.0 — Global Financial Terminal
# Environment configuration
#
# Copy to `.env` and fill secrets. Pydantic-settings reads .env at startup.
# Values are case-insensitive. Empty optional keys disable that subsystem.
# ============================================================================


# ----------------------------------------------------------------------------
# Anthropic API (LLM brain — Quant + Sentiment + Master Trader)
# ----------------------------------------------------------------------------

# Required. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Required for chart vision. Recommended: claude-opus-4-7 (best vision quality).
# Pricing in orchestrator.LLM_PRICING is hard-coded for this model
# ($15/M input, $75/M output). Cost tracker falls back to Opus 4.7's tier
# for unknown models so reports never under-estimate.
ANTHROPIC_MODEL=claude-opus-4-7


# ----------------------------------------------------------------------------
# Binance Futures Testnet
# Generate keys at https://testnet.binancefuture.com (NOT the mainnet console).
# ----------------------------------------------------------------------------

BINANCE_API_KEY=...
BINANCE_API_SECRET=...

# true = testnet (default + strongly recommended).
BINANCE_TESTNET=true


# ----------------------------------------------------------------------------
# External data feeds
# ----------------------------------------------------------------------------

# News: KEYLESS — RSS aggregator in data_fetchers/news_fetcher.py reads
# public CoinDesk / Cointelegraph / Decrypt / The Block / CryptoSlate /
# Bitcoin Magazine / CryptoPanic-RSS feeds. CryptoPanic's paid Developer
# API was discontinued (April 2026); their free RSS endpoint still works
# and is in the curated feed list.

# FRED macro: DFF, DGS10, T10Y2Y, VIXCLS, DTWEXBGS.
FRED_API_KEY=

# DefiLlama is keyless — nothing to set.


# ----------------------------------------------------------------------------
# Database (SQLAlchemy async ORM)
#
# Two supported backends, swap by changing this one URL — no code change.
#
# (a) SQLite (default, zero-setup):
#     DATABASE_URL=sqlite+aiosqlite:///traderay.db
#     WAL mode + busy_timeout + foreign_keys are applied automatically.
#
# (b) Supabase PostgreSQL via PgBouncer (transaction-mode pooler, :6543):
#     The connect_args fix (prepared_statement_cache_size=0 +
#     statement_cache_size=0) is applied automatically when the URL starts
#     with postgresql:// — required for asyncpg + PgBouncer transaction pool.
#     Use the raw connection string from Supabase (NOT URL-encoded — Pydantic
#     reads this verbatim and asyncpg handles the password as-is).
# ----------------------------------------------------------------------------

DATABASE_URL=postgresql+asyncpg://postgres:ForumArac!65432.@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Optional: set to "true" to dump every SQL statement (debugging only).
DB_ECHO=false


# ----------------------------------------------------------------------------
# Redis (live state + UI cache + dynamic-screener flag)
# ----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0


# ----------------------------------------------------------------------------
# Telegram notifications (optional — leave blank to disable entirely)
#
# 1. Create a bot via @BotFather, save the token here.
# 2. Send any message to your bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your numeric
#    chat_id (or use @userinfobot).
# 3. If either var is empty, core/telegram_notifier silently no-ops on every
#    call — system runs identically without Telegram.
# ----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ----------------------------------------------------------------------------
# Trade & risk parameters
# ----------------------------------------------------------------------------

# Boot-time default symbol roster for CRYPTO (the dashboard / DB owns it
# afterwards; this is only the first-boot seed).
SYMBOLS=BTCUSDT,ETHUSDT

# Quote asset for Crypto auto-bot orders (Binance USDT-margined perps).
QUOTE_ASSET=USDT

# Paper portfolio size for risk math. risk_manager + Master Trader prompt
# both enforce risk_usd ≤ PORTFOLIO_NOTIONAL × MAX_RISK_PCT.
PORTFOLIO_NOTIONAL=10000

# Hard cap on risk per trade. 0.02 = 2%. The Risk Manager rejects orders
# exceeding this in code (not just in prompt) — defense in depth.
MAX_RISK_PCT=0.02

# Leverage cap for Binance Futures. Risk Manager rejects anything above.
DEFAULT_LEVERAGE=3


# ----------------------------------------------------------------------------
# Legacy cadence variables (unused — kept for backward compat)
# The active scheduler derives intervals from MarketConfig.term:
#   SCALP       → every 5 min
#   SHORT_TERM  → every 1 hour
#   MID_TERM    → every 24 hours
# Tracker maintenance jobs run every 5 minutes; daily digest at 00:00 UTC.
# ----------------------------------------------------------------------------

FETCH_1M_SECONDS=60
FETCH_5M_SECONDS=300
FETCH_15M_SECONDS=900
SENTIMENT_SECONDS=600
MACRO_SECONDS=3600
DECISION_SECONDS=300


# ----------------------------------------------------------------------------
# UI / Logging
# ----------------------------------------------------------------------------

STREAMLIT_PORT=8501

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
